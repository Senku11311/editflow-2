{
  "version": 2,
  "public": true,
  "routes": [
    { "handle": "filesystem" },
    { "src": "/tutorials", "dest": "/tutorials/index.html" },
    { "src": "/ai-assistant", "dest": "/ai-assistant/index.html" },
    { "src": "/resources", "dest": "/resources/index.html" },
    { "src": "/troubleshooting", "dest": "/troubleshooting/index.html" },
    { "src": "/community", "dest": "/community/index.html" },
    { "src": "/admin", "dest": "/admin/index.html" },
    { "src": "/login", "dest": "/login/index.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "headers": [
    {
      "source": "/shared/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
